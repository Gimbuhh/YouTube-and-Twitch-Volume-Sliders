{
  "name": "youtube-twitch-volume-sliders",
  "version": "2.4.4",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test",
    "test:unit": "node --test \"tests/unit/*.test.js\"",
    "test:integration": "node --test \"tests/integration/*.test.js\"",
    "check:syntax": "node scripts/check-syntax.mjs",
    "check:metadata": "node scripts/validate-metadata.mjs",
    "check:generated": "node scripts/verify-generated.mjs",
    "check:archive": "node scripts/archive-manifest.mjs",
    "check:security": "node scripts/security-scan.mjs",
    "history:generate": "node scripts/generate-historical-releases.mjs",
    "check": "node scripts/archive-manifest.mjs && node scripts/build.mjs && node scripts/validate-metadata.mjs && node scripts/check-syntax.mjs && node --test && node scripts/verify-generated.mjs && node scripts/security-scan.mjs",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "esbuild": "0.25.5",
    "jsdom": "26.1.0"
  }
}
